#!/usr/bin/env bash
# postrm script for diepxuan-repositories
#
# see: dh_installdeb(1)

set -e

case "$1" in
remove)
    echo "[diepxuan-repositories] Package removed."
    ;;

purge)
    echo "[diepxuan-repositories] Purging configuration..."

    # Remove GPG key
    [[ -f /usr/share/keyrings/diepxuan.gpg ]] && rm -f /usr/share/keyrings/diepxuan.gpg
    [[ -f /etc/apt/trusted.gpg.d/diepxuan.gpg ]] && rm -f /etc/apt/trusted.gpg.d/diepxuan.gpg

    # Remove sources list
    [[ -f /etc/apt/sources.list.d/diepxuan.list ]] && rm -f /etc/apt/sources.list.d/diepxuan.list

    # Remove apt cache
    sudo rm -rf /var/lib/apt/lists/diepxuan* 2>/dev/null || true

    echo "[diepxuan-repositories] Configuration purged."
    ;;

upgrade | failed-upgrade | abort-install | abort-upgrade | disappear) ;;

*)
    echo "[diepxuan-repositories] postrm called with unknown argument: '$1'" >&2
    exit 1
    ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.
#DEBHELPER#
exit 0
